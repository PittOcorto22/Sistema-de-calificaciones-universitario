<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="15.0" prefHeight="400.0" prefWidth="300.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.edu.udelp.sistemaCalificaciones.controller.loginController">
    <Label text="Sistema de Calificaciones" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <TextField fx:id="txtCorreo" promptText="Correo institucional" maxWidth="200"/>
    <PasswordField fx:id="txtContrasena" promptText="Contraseña" maxWidth="200"/>
    <Button text="Ingresar" onAction="#iniciarSesion"/>
    <Label fx:id="lblMensaje" textFill="red"/>
</VBox>