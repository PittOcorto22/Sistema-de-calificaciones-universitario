<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<BorderPane prefHeight="550.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.edu.udelp.sistemaCalificaciones.controller.profesorController">

    <top>
        <VBox alignment="CENTER" spacing="10.0" style="-fx-padding: 20px;">
            <Label text="Módulo de Calificaciones" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Label fx:id="lblBienvenida" style="-fx-font-size: 16px;"/>
        </VBox>
    </top>

    <left>
        <VBox spacing="15.0" style="-fx-padding: 20px; -fx-background-color: #f4f4f4; -fx-border-color: #cccccc; -fx-border-width: 0 1 0 0;" prefWidth="250.0">
            <Label text="Capturar Calificación" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <ComboBox fx:id="cmbAlumno" promptText="Seleccionar Alumno" prefWidth="200.0"/>
            <ComboBox fx:id="cmbGrupo" promptText="Seleccionar Grupo" prefWidth="200.0"/>
            <TextField fx:id="txtParciales" promptText="Puntaje Parciales"/>
            <TextField fx:id="txtActividades" promptText="Puntaje Actividades"/>
            <Button text="Guardar Nueva" onAction="#guardarCalificacion" style="-fx-background-color: #c3924a; -fx-text-fill: white; -fx-font-weight: bold;" prefWidth="200.0"/>
            <Button text="Actualizar Seleccionada" onAction="#actualizarCalificacion" style="-fx-background-color: #5bc0de; -fx-text-fill: white; -fx-font-weight: bold;" prefWidth="200.0"/>
            <Label fx:id="lblMensajeForm" textFill="red" wrapText="true"/>
        </VBox>
    </left>

    <center>
        <VBox style="-fx-padding: 20px;" spacing="10.0">
            <TableView fx:id="tablaCalificaciones" VBox.vgrow="ALWAYS" onMouseClicked="#seleccionarCalificacion">
                <columns>
                    <TableColumn text="ID" prefWidth="40.0">
                        <cellValueFactory><PropertyValueFactory property="id" /></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Alumno" prefWidth="150.0">
                        <cellValueFactory><PropertyValueFactory property="nombreAlumno" /></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Materia" prefWidth="200.0">
                        <cellValueFactory><PropertyValueFactory property="nombreGrupo" /></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Parciales" prefWidth="80.0">
                        <cellValueFactory><PropertyValueFactory property="parciales" /></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Actividades" prefWidth="80.0">
                        <cellValueFactory><PropertyValueFactory property="actividades" /></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Promedio" prefWidth="80.0">
                        <cellValueFactory><PropertyValueFactory property="promedioFinal" /></cellValueFactory>
                    </TableColumn>
                </columns>
            </TableView>
            <HBox spacing="15.0" alignment="CENTER">
                <Button text="Cerrar Sesion" onAction="#cerrarSesion"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>